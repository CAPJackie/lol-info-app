{
  "name": "lol-info-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean-dev": "rm -rf node_modules && yarn && yarn dev",
    "dev": "next dev --turbo",
    "build": "next build",
    "build:verify": "yarn format:check && yarn lint && yarn build && yarn perf:routes",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "perf:routes": "node scripts/check-route-performance.mjs",
    "docker:verify": "docker compose build verify && docker compose run --rm verify",
    "docker:app": "docker compose up --build app",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@faker-js/faker": "^10.3.0",
    "@mui/material": "^7.3.9",
    "@types/antd": "^1.0.0",
    "@types/node": "20.19.37",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/analytics": "^2.0.0",
    "@vercel/kv": "^0.2.4",
    "antd": "^6.3.2",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.6",
    "limiter": "^3.0.0",
    "next": "16.1.6",
    "npm-check-updates": "^19.6.3",
    "react": "19.2.4",
    "react-awesome-reveal": "^4.3.1",
    "react-dom": "19.2.4",
    "sass": "^1.98.0",
    "sharp": "^0.34.5",
    "typescript": "5.9.3"
  },
